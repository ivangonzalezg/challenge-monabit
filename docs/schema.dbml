// MonaBit - Crypto Dashboard
// Conceptual data model. Persistence layer: SQL (PostgreSQL-compatible).
// Visualize at: https://dbdiagram.io
// Full documentation: docs/database/database-schema.md
//
// Authentication: Better Auth (internal library, not an external hosted provider).
// Better Auth owns the core auth schema: user, session, account, verification.
// MonaBit extends the Better Auth user with application fields (role, status).
// The tables below represent the MonaBit application schema only.
// Better Auth tables are auto-generated by the library during setup.

// ---------------------------------------------------------------------------
// BETTER AUTH — auto-generated tables (do not define manually)
// ---------------------------------------------------------------------------
// Better Auth will create and manage these tables:
//
//   user          — core user identity (id, email, name, image, emailVerified, etc.)
//   session       — cookie-based sessions (token, userId, expiresAt, ipAddress, userAgent)
//   account       — linked provider accounts (userId, providerId, accountId, password, etc.)
//   verification  — email/magic-link verification tokens
//
// These tables are NOT defined here. Better Auth generates them based on the
// configured plugins and the selected database adapter.
// Reference: https://www.better-auth.com/docs/concepts/database

// ---------------------------------------------------------------------------
// MONABIT USER EXTENSIONS
// ---------------------------------------------------------------------------

// MonaBit extends the Better Auth user with application-level fields.
// In practice, these can be added as additional columns on the Better Auth
// `user` table (Better Auth supports additional fields) or kept in a separate
// profile table if the ORM/schema approach requires it.
//
// This table documents the MonaBit-owned user fields.
// The `id` here references the Better Auth `user.id` (same primary key).
Table user_extensions {
  id       varchar [pk, note: "Same id as Better Auth user.id"]
  role     varchar [not null, default: "user", note: "user | admin"]
  status   varchar [not null, default: "active", note: "active | inactive | blocked | deleted"]

  Note: "MonaBit application fields extending the Better Auth user. role and status are application-owned. If the ORM supports it, these can be additional columns on the Better Auth user table directly instead of a separate table."
}

// ---------------------------------------------------------------------------
// USER PROFILE
// ---------------------------------------------------------------------------

// Extended profile data. user_id references Better Auth user.id.
// No currency field — all market data is USD only for the MVP.
Table user_profiles {
  id           varchar   [pk, default: `gen_random_uuid()`]
  user_id      varchar   [not null, ref: - user_extensions.id]
  display_name varchar
  bio          varchar
  country      varchar   [note: "ISO 3166-1 alpha-2"]
  timezone     varchar   [note: "IANA timezone"]
  created_at   timestamp [not null, default: `now()`]
  updated_at   timestamp [not null, default: `now()`]

  indexes {
    user_id [unique, name: "uq_user_profiles_user"]
  }
}

// Stores user-to-asset relationship only. No market values.
// Market data is resolved from crypto_assets at query time.
// user_id references Better Auth user.id.
Table user_favorite_cryptos {
  id                varchar    [pk, default: `gen_random_uuid()`]
  user_id           varchar    [not null, ref: > user_extensions.id]
  provider_asset_id varchar    [not null, ref: > crypto_assets.provider_asset_id]
  symbol            varchar    [not null]
  name              varchar    [not null]
  created_at        timestamp  [not null, default: `now()`]

  indexes {
    (user_id, provider_asset_id) [unique, name: "uq_user_favorites"]
  }
}

// ---------------------------------------------------------------------------
// CRYPTO MARKET DATA  (shared, not user-owned)
// ---------------------------------------------------------------------------

// Local synchronized catalog. Up to 250 assets from CoinGecko, upserted every 10 min.
// Source for: dashboard Top 10, local search, favorites resolution, alert evaluation.
Table crypto_assets {
  id                       varchar   [pk, default: `gen_random_uuid()`]
  provider                 varchar   [not null, note: "coingecko"]
  provider_asset_id        varchar   [not null, unique, note: "e.g. bitcoin, ethereum"]
  symbol                   varchar   [not null]
  name                     varchar   [not null]
  image_url                varchar
  market_cap_rank          integer
  is_active                boolean   [not null, default: true, note: "false if absent from latest sync"]
  current_price_usd        numeric   [not null]
  market_cap_usd           numeric
  total_volume_usd         numeric
  high_24h_usd             numeric
  low_24h_usd              numeric
  price_change_24h_usd     numeric
  price_change_pct_1h      numeric
  price_change_pct_24h     numeric
  price_change_pct_7d      numeric
  circulating_supply       numeric
  total_supply             numeric
  max_supply               numeric
  ath_usd                  numeric
  ath_change_pct           numeric
  ath_date                 timestamp
  atl_usd                  numeric
  atl_change_pct           numeric
  atl_date                 timestamp
  sparkline_7d             jsonb     [note: "7-day price array for sparkline chart"]
  provider_updated_at      timestamp
  last_synced_at           timestamp [not null]
  created_at               timestamp [not null, default: `now()`]
  updated_at               timestamp [not null, default: `now()`]
}

// Global market KPIs from CoinGecko /global.
// Used for dashboard KPI cards. Describes the whole market, not individual assets.
Table crypto_market_kpis {
  id                        varchar   [pk, default: `gen_random_uuid()`]
  provider                  varchar   [not null, note: "coingecko"]
  active_cryptocurrencies   integer
  markets                   integer
  total_market_cap_usd      numeric
  total_volume_usd          numeric
  btc_dominance_pct         numeric
  eth_dominance_pct         numeric
  usdt_dominance_pct        numeric
  market_cap_change_pct_24h numeric
  volume_change_pct_24h     numeric
  provider_updated_at       timestamp
  last_synced_at            timestamp [not null]
  created_at                timestamp [not null, default: `now()`]
  updated_at                timestamp [not null, default: `now()`]
}

// Sync operation log. 2 CoinGecko calls per run, every 10 minutes.
Table crypto_sync_runs {
  id               varchar   [pk, default: `gen_random_uuid()`]
  provider         varchar   [not null, note: "coingecko"]
  sync_type        varchar   [not null, note: "market_dashboard"]
  status           varchar   [not null, note: "success | failed | partial_success"]
  started_at       timestamp [not null]
  finished_at      timestamp
  duration_ms      integer
  endpoints_used   jsonb
  calls_used       integer
  assets_requested integer
  assets_updated   integer
  kpis_updated     boolean
  error_message    varchar
  created_at       timestamp [not null, default: `now()`]
}

// ---------------------------------------------------------------------------
// AUDIT LOGS  (MonaBit-owned application table)
// ---------------------------------------------------------------------------

// Application-level audit trail for auth and admin events.
// actor_user_id and target_user_id reference Better Auth user.id.
Table audit_logs {
  id             varchar   [pk, default: `gen_random_uuid()`]
  actor_user_id  varchar   [ref: > user_extensions.id]
  target_user_id varchar   [ref: > user_extensions.id]
  action         varchar   [not null, note: "AUTH_REGISTER_SUCCESS | AUTH_LOGIN_SUCCESS | AUTH_LOGIN_FAILED | AUTH_GOOGLE_LOGIN_SUCCESS | AUTH_LOGOUT | USER_CREATED | USER_UPDATED | USER_BLOCKED | USER_UNBLOCKED | USER_DEACTIVATED | USER_DELETED | USER_ROLE_UPDATED"]
  metadata       jsonb
  ip_address     varchar
  user_agent     varchar
  created_at     timestamp [not null, default: `now()`]
}

// ---------------------------------------------------------------------------
// OPTIONAL — FUTURE FEATURES
// ---------------------------------------------------------------------------

// Alerts evaluate against crypto_assets.current_price_usd, not CoinGecko directly.
// user_id references Better Auth user.id.
Table price_alerts {
  id                varchar   [pk, default: `gen_random_uuid()`]
  user_id           varchar   [not null, ref: > user_extensions.id]
  provider_asset_id varchar   [not null, ref: > crypto_assets.provider_asset_id]
  symbol            varchar   [not null]
  target_price_usd  numeric   [not null]
  condition         varchar   [not null, note: "above | below"]
  status            varchar   [not null, default: "active", note: "active | triggered | disabled"]
  created_at        timestamp [not null, default: `now()`]
  updated_at        timestamp [not null, default: `now()`]
  triggered_at      timestamp
}
