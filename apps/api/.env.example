# Server
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
WEB_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgres://monabit:monabit@localhost:5432/monabit

# Better Auth
BETTER_AUTH_SECRET=change-me-min-32-chars-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:8080

# Google OAuth
GOOGLE_CLIENT_ID=example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=example-google-client-secret

# CoinGecko
CRYPTO_PROVIDER=coingecko
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=example-coingecko-api-key
CRYPTO_SYNC_SECRET=change-me-internal-sync-secret
CRYPTO_SYNC_INTERVAL_MINUTES=5
CRYPTO_DATA_STALE_AFTER_MINUTES=15
